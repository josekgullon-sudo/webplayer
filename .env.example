# URL base del panel que sirve la lista. Usa HTTPS: asi el dominio y las
# credenciales viajan cifrados entre este servidor y el panel.
PLAYLIST_BASE_URL=https://patorojo.eu
# Secreto de sesion. Generalo con: openssl rand -hex 32
# Cifra tambien las URLs de origen y las credenciales guardadas.
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria
# Puerto del web player
PORT=4000
# Pon true cuando sirvas el player por HTTPS detras de nginx
COOKIE_SECURE=false
# TTL de la cache de la lista en ms (5 min)
CACHE_TTL_MS=300000
