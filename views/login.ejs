<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
  <title>Acceso — Totalflix</title>
</head>
<body class="login-page">
  <main class="login-card">
    <div class="brand brand-lg"><%- include('partials/logo') %></div>
    <h1>Entra a tu televisión</h1>
    <p class="sub">Usa el usuario y la contraseña de tu línea.</p>

    <% if (error) { %><div class="alert"><%= error %></div><% } %>

    <form method="post" action="/login">
      <div class="field">
        <label for="u">Usuario</label>
        <input id="u" type="text" name="username" required autocomplete="username" autocapitalize="none" spellcheck="false" autofocus placeholder="tu-usuario">
      </div>
      <div class="field">
        <label for="p">Contraseña</label>
        <input id="p" type="password" name="password" required autocomplete="current-password" placeholder="••••••••">
      </div>
      <button class="btn" type="submit">Entrar</button>
    </form>
  </main>
</body>
</html>
